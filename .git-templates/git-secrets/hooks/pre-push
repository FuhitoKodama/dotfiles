#!/bin/sh

# Prevent anonymous-looking pushes by requiring GitHub login and valid git identity.

if [ -n "${CI:-}" ]; then
    exit 0
fi

if ! command -v gh >/dev/null 2>&1; then
    echo "[pre-push] ERROR: gh command is required. Install GitHub CLI and login first." >&2
    exit 1
fi

if ! gh auth status -h github.com >/dev/null 2>&1; then
    echo "[pre-push] ERROR: Not logged in to GitHub. Run: gh auth login" >&2
    exit 1
fi

git_name="$(git config --get user.name || true)"
git_email="$(git config --get user.email || true)"

if [ -z "$git_name" ] || [ -z "$git_email" ]; then
    echo "[pre-push] ERROR: git user.name / user.email is not set for this repository." >&2
    echo "[pre-push] Set them with: git config user.name \"YOUR_NAME\" && git config user.email \"YOUR_EMAIL\"" >&2
    exit 1
fi

case "$git_name:$git_email" in
    *YOUR_NAME*|*YOUR_EMAIL*)
        echo "[pre-push] ERROR: Placeholder identity detected in git config." >&2
        echo "[pre-push] Update ~/.gitconfig.local (or repo local config) before pushing." >&2
        exit 1
        ;;
esac

allowed_emails=""
if emails_out="$(gh api user/emails --paginate -q '.[].email' 2>/dev/null)"; then
    allowed_emails="$emails_out"
fi

if printf '%s\n' "$allowed_emails" | grep -q '@'; then
    if ! printf '%s\n' "$allowed_emails" | grep -Fxq "$git_email"; then
        echo "[pre-push] ERROR: git user.email is not registered on the logged-in GitHub account." >&2
        echo "[pre-push] Current email: $git_email" >&2
        echo "[pre-push] Set a registered email or GitHub noreply address, then retry." >&2
        exit 1
    fi
else
    login="$(gh api user -q .login 2>/dev/null || true)"
    if [ -n "$login" ]; then
        case "$git_email" in
            *"@users.noreply.github.com")
                case "$git_email" in
                    *"$login"*) ;;
                    *)
                        echo "[pre-push] ERROR: noreply email does not match logged-in GitHub user ($login)." >&2
                        exit 1
                        ;;
                esac
                ;;
            *)
                echo "[pre-push] WARNING: Could not validate user/emails scope. Run: gh auth refresh -h github.com -s user" >&2
                echo "[pre-push] WARNING: Ensure '$git_email' is registered on GitHub." >&2
                ;;
        esac
    fi
fi

exit 0
